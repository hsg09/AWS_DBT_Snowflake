# =============================================================================
# .gitignore for AWS DBT Snowflake project
# =============================================================================

# ----- dbt -----
target/                 # compiled SQL, run artifacts
dbt_packages/           # installed via `dbt deps` — not committed
logs/
.dbt/
.user.yml
airflow/*.generated

# CRITICAL: profiles.yml contains credentials even if values are env_var().
# The committed profiles.yml is a template. Actual profiles with real values
# should NEVER be committed. Add this rule as a double-safety net.
# profiles.yml   <-- commented out because we DO commit the template
# Uncomment if you put real credentials directly in profiles.yml

# ----- Python -----
.venv/
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.eggs/

# ----- macOS -----
.DS_Store
.AppleDouble
.LSOverride

# ----- IDE -----
.vscode/
.idea/
*.swp
*.swo
*~

# ----- Environment & Secrets -----
.env
.env.*
*.pem
*.key
secrets/
credentials/

# ----- Airflow -----
airflow/logs/
airflow/plugins/
airflow.db*           # Ignores .db, .db-shm, .db-wal
airflow.cfg
airflow/*.generated
airflow/standalone_admin_password.txt

# ----- Testing -----
.pytest_cache/
.coverage
htmlcov/

# ----- Misc -----
*.log
*.tmp
*.bak
