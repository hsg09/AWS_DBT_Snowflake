  'high','medium','low'\n)\n\n\n", "relation_name": "ANALYTICS.DEV_LOCAL_dbt_test__audit.accepted_values_dim_products_margin_tier__high__medium__low", "batch_results": null}, {"status": "pass", "timing": [{"name": "compile", "started_at": "2026-03-31T16:16:57.221616Z", "completed_at": "2026-03-31T16:16:57.247161Z"}, {"name": "execute", "started_at": "2026-03-31T16:16:57.327370Z", "completed_at": "2026-03-31T16:16:58.741924Z"}], "thread_id": "Thread-14 (worker)", "execution_time": 1.8516979217529297, "adapter_response": {"_message": "SUCCESS 1", "code": "SUCCESS", "rows_affected": 1, "query_id": "01c36630-0001-6079-0000-978d00135d1e"}, "message": null, "failures": 0, "unique_id": "test.aws_dbt_snowflake_project.assert_orders_revenue_matches_line_items", "compiled": true, "compiled_code": "\n\n-- =============================================================================\n-- Test: assert_orders_revenue_matches_line_items.sql\n-- Type: Singular (custom) test\n-- Purpose:\n--   Cross-check: the sum of line item totals for completed orders should\n--   be within 5% tolerance of the order header revenue_usd.\n--   Large discrepancies indicate data corruption or calculation errors.\n-- =============================================================================\n\nWITH order_header AS (\n    SELECT\n        order_id,\n        revenue_usd             AS header_revenue_usd\n    FROM ANALYTICS.DEV_LOCAL_marts.fct_orders\n    WHERE is_completed = TRUE\n),\n\norder_item_totals AS (\n    SELECT\n        order_id,\n        SUM(line_total_usd)     AS computed_revenue_usd\n    FROM ANALYTICS.DEV_LOCAL_staging.stg_raw__order_items\n    GROUP BY 1\n),\n\ndiscrepancies AS (\n    SELECT\n        h.order_id,\n        h.header_revenue_usd,\n        t.computed_revenue_usd,\n        ABS(h.header_revenue_usd - COALESCE(t.computed_revenue_usd, 0)) AS abs_diff,\n        CASE\n            WHEN h.header_revenue_usd > 0\n            THEN ABS(h.header_revenue_usd - COALESCE(t.computed_revenue_usd, 0))\n                 / h.header_revenue_usd * 100\n            ELSE 0\n        END AS pct_diff\n    FROM order_header AS h\n    LEFT JOIN order_item_totals AS t USING (order_id)\n    WHERE pct_diff > 5   -- flag orders with >5% mismatch\n      AND abs_diff > 1   -- ignore rounding noise (< $1 diff)\n)\n\nSELECT * FROM discrepancies", "relation_name": "ANALYTICS.DEV_LOCAL_dbt_test__audit.assert_orders_revenue_matches_line_items", "batch_results": null}, {"status": "pass", "timing": [{"name": "compile", "started_at": "2026-03-31T16:16:57.217687Z", "completed_at": "2026-03-31T16:16:57.230923Z"}, {"name": "execute", "started_at": "2026-03-31T16:16:57.249354Z", "completed_at": "2026-03-31T16:16:58.833464Z"}], "thread_id": "Thread-12 (worker)", "execution_time": 1.8663480281829834, "adapter_response": {"_message": "SUCCESS 1", "code": "SUCCESS", "rows_affected": 1, "query_id": "01c36630-0001-60a6-0000-978d00136a66"}, "message": null, "failures": 0, "unique_id": "test.aws_dbt_snowflake_project.assert_no_duplicate_order_keys", "compiled": true, "compiled_code": "\n\n-- =============================================================================\n-- Test: assert_no_duplicate_order_keys.sql\n-- Type: Singular (custom) test\n-- Purpose:\n--   Detect duplicate order_sk values in fct_orders.\n--   Duplicates indicate a bug in surrogate key generation or incremental merge logic.\n--   Should return 0 rows in a healthy pipeline.\n-- =============================================================================\n\nWITH order_counts AS (\n    SELECT\n        order_sk,\n        COUNT(*) AS row_count\n    FROM ANALYTICS.DEV_LOCAL_marts.fct_orders\n    GROUP BY 1\n    HAVING COUNT(*) > 1\n)\n\nSELECT\n    order_sk,\n    row_count\nFROM order_counts", "relation_name": "ANALYTICS.DEV_LOCAL_dbt_test__audit.assert_no_duplicate_order_keys", "batch_results": null}, {"status": "pass", "timing": [{"name": "compile", "started_at": "2026-03-31T16:16:57.219229Z", "completed_at": "2026-03-31T16:16:57.231096Z"}, {"name": "execute", "started_at": "2026-03-31T16:16:57.251513Z", "completed_at": "2026-03-31T16:16:58.908056Z"}], "thread_id": "Thread-13 (worker)", "execution_time": 1.977351188659668, "adapter_response": {"_message": "SUCCESS 1", "code": "SUCCESS", "rows_affected": 1, "query_id": "01c36630-0001-60a6-0000-978d00136a6a"}, "message": null, "failures": 0, "unique_id": "test.aws_dbt_snowflake_project.assert_orders_have_valid_customers", "compiled": true, "compiled_code": "\n\n-- =============================================================================\n-- Test: assert_orders_have_valid_customers.sql\n-- Type: Singular (custom) test\n-- Purpose:\n--   Ensure every order in fct_orders has a matching, valid customer in dim_customers.\n--   Flags orphaned orders (customer_id not found in dimension = data quality failure).\n--\n-- Expectation: returns 0 rows (all orders have valid customers)\n-- Severity: error (blocks deployment if orphans exist in prod)\n-- =============================================================================\n\nWITH orphaned_orders AS (\n    SELECT\n        fo.order_id,\n        fo.customer_id,\n        fo.order_date_day,\n        fo.order_status\n    FROM ANALYTICS.DEV_LOCAL_marts.fct_orders AS fo\n    LEFT JOIN ANALYTICS.DEV_LOCAL_marts.dim_customers AS dc\n        ON fo.customer_sk = dc.customer_sk\n    WHERE dc.customer_sk IS NULL\n      -- Exclude very recent orders where customer dim may not yet be refreshed\n      AND fo.order_date_day < DATEADD('hour', -6, CURRENT_DATE())\n)\n\nSELECT * FROM orphaned_orders", "relation_name": "ANALYTICS.DEV_LOCAL_dbt_test__audit.assert_orders_have_valid_customers", "batch_results": null}, {"status": "pass", "timing": [{"name": "compile", "started_at": "2026-03-31T16:16:58.842784Z", "completed_at": "2026-03-31T16:16:58.848590Z"}, {"name": "execute", "started_at": "2026-03-31T16:16:58.848854Z", "completed_at": "2026-03-31T16:16:59.980500Z"}], "thread_id": "Thread-8 (worker)", "execu