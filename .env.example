# Snowflake Connection Credentials
# -----------------------------------------------------------------------------
SNOWFLAKE_ACCOUNT=your_account.region       # e.g. xyz12345.us-east-1
SNOWFLAKE_USER=your_username
SNOWFLAKE_PASSWORD=your_password

# Optional Overrides (Defaults set in profiles.yml)
# -----------------------------------------------------------------------------
# SNOWFLAKE_ROLE=DATA_ENGINEER
# SNOWFLAKE_WAREHOUSE=TRANSFORMER_WH
# SNOWFLAKE_DATABASE=ANALYTICS

# Developer Configuration
# -----------------------------------------------------------------------------
# DBT_DEV_USER=your_name                    # used for individual dev schemas
